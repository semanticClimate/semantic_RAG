FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-this-in-production

REDIS_URL=redis://localhost:6379/0

CHROMA_PATH=./chroma_db
CHROMA_COLLECTION=climate_academy

EMBEDDING_MODEL=all-MiniLM-L6-v2

LLM_PROVIDER=auto
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

GROK_API_KEY=
GROK_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-4.3
GROK_TIMEOUT_SECONDS=120

CHUNK_SIZE=150
CHUNK_OVERLAP=30
CHUNK_MODE=default
SOURCE_HTML_PATH=input/climate_academy.html
SOURCE_HTML_PATHS=input/climate_academy.html,input/climate_filtered.html

TOP_K=5
DISTANCE_THRESHOLD=0.7

SESSION_TTL_SECONDS=86400

LOG_LEVEL=INFO   # DEBUG for development, INFO for production

GUNICORN_WORKERS=4
LOG_DIR=/var/log/climate-rag
